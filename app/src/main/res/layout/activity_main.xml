<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="@dimen/screen_padding_h"
        android:paddingEnd="@dimen/screen_padding_h"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Header com Créditos (Estilo novo) -->
        <LinearLayout
            android:id="@+id/llHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent"
            android:paddingVertical="@dimen/spacing_sm">

            <!-- Badge de Créditos -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_credits_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_lightning"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvCredits"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2/2 Créditos"
                    android:textColor="#3D4766"
                    android:textStyle="bold"
                    android:textSize="13sp" />

                <ProgressBar
                    android:id="@+id/pbCredits"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <!-- Botão Upgrade -->
            <LinearLayout
                android:id="@+id/btnUpgrade"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_upgrade_btn"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_crown"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_upgrade"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="13sp" />
            </LinearLayout>

            <View
                android:layout_width="12dp"
                android:layout_height="0dp" />

            <!-- User Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_user_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_user"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="samuel"
                    android:textColor="#3D4766"
                    android:textSize="13sp" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Logout -->
            <ImageButton
                android:id="@+id/btnLogout"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_logout" />

        </LinearLayout>

        <!-- Título -->
        <TextView
            android:id="@+id/tvHomeTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textSize="@dimen/text_headline"
            android:textStyle="bold"
            android:textColor="@color/primaryTextColor"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="@dimen/spacing_md"
            app:layout_constraintTop_toBottomOf="@id/llHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvHomeSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/home_subtitle"
            android:textAlignment="center"
            android:textColor="@color/secondaryTextColor"
            android:textSize="@dimen/text_body"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginTop="@dimen/spacing_sm"
            app:layout_constraintTop_toBottomOf="@id/tvHomeTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Área de upload -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUpload"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:cardCornerRadius="@dimen/corner_card"
            app:cardElevation="0dp"
            app:strokeColor="@color/borderColor"
            app:strokeWidth="2dp"
            app:cardBackgroundColor="@color/colorSurface"
            android:layout_marginTop="@dimen/section_gap"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@id/tvHomeSubtitle"
            app:layout_constraintBottom_toTopOf="@id/tvSupportedFormats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/spacing_xl">

                <ImageView
                    android:layout_width="@dimen/icon_size_lg"
                    android:layout_height="@dimen/icon_size_lg"
                    android:src="@android:drawable/ic_menu_upload"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:contentDescription="@string/home_upload_icon_desc"
                    app:tint="@color/primaryColor" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_upload_box"
                    android:textAlignment="center"
                    android:textColor="@color/secondaryTextColor"
                    android:textSize="@dimen/text_body"
                    android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Texto de formatos suportados -->
        <TextView
            android:id="@+id/tvSupportedFormats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_upload_box"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/hintTextColor"
            android:layout_marginTop="@dimen/spacing_sm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Loading Overlay -->
    <include
        android:id="@+id/loadingOverlay"
        layout="@layout/view_loading_overlay" />

</FrameLayout>

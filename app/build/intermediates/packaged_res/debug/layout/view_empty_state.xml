<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/emptyStateRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/spacing_xl"
    android:visibility="gone">

    <ImageView
        android:id="@+id/emptyStateIcon"
        android:layout_width="@dimen/icon_size_xl"
        android:layout_height="@dimen/icon_size_xl"
        android:src="@android:drawable/ic_menu_gallery"
        app:tint="@color/primaryLightColor"
        android:contentDescription="@string/empty_state_title" />

    <TextView
        android:id="@+id/emptyStateTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        android:text="@string/empty_state_title"
        android:textSize="@dimen/text_title"
        android:textColor="@color/primaryTextColor"
        android:textStyle="bold"
        android:gravity="center" />

    <TextView
        android:id="@+id/emptyStateMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/empty_state_message"
        android:textSize="@dimen/text_body"
        android:textColor="@color/secondaryTextColor"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/emptyStateRetryBtn"
        style="@style/RoundedOutlineButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="@string/action_retry" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Prévia da imagem -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.2"
            app:cardCornerRadius="@dimen/corner_card"
            app:cardElevation="@dimen/elevation_card"
            app:cardBackgroundColor="@color/black"
            android:layout_marginBottom="@dimen/spacing_md">

            <ImageView
                android:id="@+id/ivPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:contentDescription="@string/preview_image_description" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Painel de edição -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardCornerRadius="@dimen/corner_card"
            app:cardElevation="@dimen/elevation_card"
            app:cardBackgroundColor="@color/colorSurface">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/edit_section_title"
                        android:textStyle="bold"
                        android:textSize="@dimen/text_subtitle"
                        android:textColor="@color/primaryTextColor"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPrompt"
                        style="@style/Widget.EditFlow.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/prompt_hint"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPrompt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minLines="3"
                            android:gravity="top|start"
                            android:inputType="textMultiLine"
                            android:imeOptions="flagNoEnterAction" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGenerate"
                        style="@style/RoundedButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:text="@string/edit_generate_btn"
                        android:layout_marginTop="@dimen/spacing_sm" />

                </LinearLayout>
            </ScrollView>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Loading Overlay -->
    <include
        android:id="@+id/loadingOverlay"
        layout="@layout/view_loading_overlay" />

</FrameLayout>
